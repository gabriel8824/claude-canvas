{
  "name": "claude-canvas-server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/bundle.js --external:better-sqlite3 --external:node-pty",
    "start": "node dist/index.js",
    "postinstall": "node -e \"const{execSync}=require('child_process');const p=process.platform,a=process.arch==='arm64'?'arm64':'x64';if(p==='darwin'||p==='linux'){try{execSync('chmod +x ../node_modules/node-pty/prebuilds/'+p+'-'+a+'/spawn-helper')}catch(_){}}\""
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-pty": "^1.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
