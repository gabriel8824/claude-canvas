# Server port (default: 3001)
PORT=3001

# Database file path (default: ~/.claude-canvas.db)
# DB_PATH=/path/to/custom/canvas.db

# Anthropic API key for AI features (commit message generation, code review)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# CORS allowed origin (default: localhost:3001 and localhost:5173)
# CORS_ORIGIN=https://your-domain.com

# Node environment
NODE_ENV=development
